<Window x:Class="AutoRpaTool.MainWindow"
        x:Name="MainWindowRef" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="https://miroiu.github.io/nodify"
        Title="RPA Automation Studio - Phase 2 (Fix Nối Dây Chắc Chắn)" Height="720" Width="1280">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#f0f0f0" Padding="10" BorderBrush="#ccc" BorderThickness="0,0,1,0">
            <StackPanel>
                <Button Content="+ Tạo kịch bản mới" Height="35" Margin="0,0,0,10" 
                        Click="BtnCreateScenario_Click" Background="#007ACC" Foreground="White" BorderThickness="0"/>

                <TextBlock Text="Danh sách kịch bản:" FontWeight="Bold" Margin="0,5"/>
                <ListBox x:Name="lstScenarios" DisplayMemberPath="Name" Height="450" BorderBrush="#ccc"
                         SelectionChanged="LstScenarios_SelectionChanged"/>

                <Button Content="💾 Lưu kịch bản" Height="35" Margin="0,15,0,0" 
                        Click="BtnSaveScenario_Click" Background="DimGray" Foreground="White"/>

                <Button Content="▶ CHẠY KỊCH BẢN" Background="LimeGreen" Foreground="White" FontWeight="Bold"
                        Height="40" Margin="0,10,0,0" Click="BtnRun_Click"/>
            </StackPanel>
        </Border>

        <nodify:NodifyEditor Grid.Column="1" Background="#1e1e1e" x:Name="FlowchartEditor"
                             Connections="{Binding CurrentConnections, ElementName=MainWindowRef}">

            <nodify:NodifyEditor.ItemContainerStyle>
                <Style TargetType="{x:Type nodify:ItemContainer}">
                    <Setter Property="Location" Value="{Binding Location}"/>
                </Style>
            </nodify:NodifyEditor.ItemContainerStyle>

            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate>
                    <nodify:Connection Source="{Binding Source.OutputAnchor}"
                                       Target="{Binding Target.InputAnchor}"
                                       StrokeThickness="3" Stroke="LimeGreen"/>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

            <nodify:NodifyEditor.PendingConnection>
                <nodify:PendingConnection Source="{Binding PendingWireSource, ElementName=MainWindowRef, Mode=OneWayToSource}"
                                          CompletedCommand="{Binding CreateWireCommand, ElementName=MainWindowRef}"
                                          StrokeThickness="3" StrokeDashArray="4 4" Stroke="Yellow"/>
            </nodify:NodifyEditor.PendingConnection>
            <nodify:NodifyEditor.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="➕ Thêm Node: Click chuột" Click="MenuAddClick_Click"/>
                    <MenuItem Header="➕ Thêm Node: Gõ phím" Click="MenuAddType_Click"/>
                </ContextMenu>
            </nodify:NodifyEditor.ContextMenu>

            <nodify:NodifyEditor.ItemTemplate>
                <DataTemplate>
                    <nodify:Node Width="220" BorderBrush="#555" BorderThickness="1">

                        <nodify:Node.Header>
                            <TextBlock Text="{Binding NodeType}" Foreground="White" FontWeight="Bold" Margin="5,0"/>
                        </nodify:Node.Header>

                        <StackPanel Margin="8">

                            <nodify:NodeInput Header="Nhận luồng (Input)" 
                                              Anchor="{Binding InputAnchor, Mode=OneWayToSource}" />

                            <TextBlock Text="Mục tiêu (Appid):" Foreground="LightGray" FontSize="11" Margin="0,5,0,0"/>
                            <TextBox Text="{Binding TargetData}" IsReadOnly="True" Margin="0,2,0,5" FontSize="11"
                                     Background="#333" Foreground="Yellow" BorderThickness="0" Padding="2"/>

                            <Button Content="🎯 Chọn trên màn hình" Background="#007ACC" Foreground="White" 
                                    Click="BtnPickElement_Click" Tag="{Binding}" Height="25"/>

                            <TextBlock Text="Nội dung cần nhập (nếu có):" Foreground="LightGray" FontSize="11" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,2,0,0" Padding="3" Background="White" Foreground="Black"/>

                            <nodify:NodeOutput Header="Chạy tiếp (Output)" Margin="0,15,0,0"
                                               Anchor="{Binding OutputAnchor, Mode=OneWayToSource}" />

                        </StackPanel>
                    </nodify:Node>
                </DataTemplate>
            </nodify:NodifyEditor.ItemTemplate>

        </nodify:NodifyEditor>
    </Grid>
</Window>