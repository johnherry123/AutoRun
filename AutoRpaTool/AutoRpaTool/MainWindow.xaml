<Window x:Class="AutoRpaTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:nodify="https://miroiu.github.io/nodify"
        xmlns:vm="clr-namespace:AutoRpaTool.ViewModels"
        xmlns:models="clr-namespace:AutoRpaTool.Models"
        xmlns:local="clr-namespace:AutoRpaTool"
        Title="RPA Studio — Image Based" Height="760" Width="1400"
        Background="#1a1a2e">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Style chung cho Button -->
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="8,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Style cho ComboBox dropdown item: chu trang tren nen toi -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1a1a2e"/>
            <Setter Property="Padding" Value="6,4"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#0f3460"/>
                    <Setter Property="Foreground" Value="#00AEFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#16213e"/>
                    <Setter Property="Foreground" Value="#00AEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Converter: file path → BitmapImage thumbnail -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:StringToVisibilityConverter x:Key="StrToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="290"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#16213e" Padding="10">
            <StackPanel>
                <TextBlock Text=" FRA Studio" Foreground="#00AEFF" FontSize="18"
                           FontWeight="Bold" Margin="0,0,0,15"/>

                <Button Content="＋ Tạo kịch bản mới" Background="#0f3460"
                        Style="{StaticResource BtnStyle}"
                        Command="{Binding CreateScenarioCommand}"/>
                <Button Content="🗑 Xóa kịch bản" Background="#7f1d1d"
                        Style="{StaticResource BtnStyle}"
                        Command="{Binding DeleteScenarioCommand}"/>

                <Separator Margin="0,10" Background="#ffffff22"/>

                <TextBlock Text="Danh sách kịch bản:" Foreground="#aaa" FontSize="11" Margin="0,0,0,5"/>
                <ListBox ItemsSource="{Binding Scenarios}"
                         SelectedItem="{Binding SelectedScenario}"
                         DisplayMemberPath="Name"
                         Height="320"
                         Background="#0d1b2a" Foreground="White"
                         BorderBrush="#ffffff22" BorderThickness="1"/>

                <!-- Trigger window -->
                <TextBlock Text="Trigger: Tiêu đề cửa sổ" Foreground="#aaa" FontSize="11" Margin="0,12,0,3"/>
                <TextBox Text="{Binding SelectedScenario.TriggerWindowTitle, UpdateSourceTrigger=PropertyChanged}"
                         Background="#0d1b2a" Foreground="White" BorderBrush="#00AEFF"
                         Padding="5,4" IsEnabled="{Binding IsNodeSelected, Converter={StaticResource BoolToVis}}"/>

                <Separator Margin="0,12" Background="#ffffff22"/>

                <Button Content="💾 Lưu" Background="#065f46" Style="{StaticResource BtnStyle}"
                        Command="{Binding SaveScenarioCommand}"/>
                <Button Content="▶ CHẠY KỊCH BẢN" Background="#15803d" Style="{StaticResource BtnStyle}"
                        Height="40" FontSize="14" Margin="0,6"
                        Command="{Binding RunScenarioCommand}"/>
                <Button Content="⏹ Dừng" Background="#7f1d1d" Style="{StaticResource BtnStyle}"
                        Command="{Binding StopScenarioCommand}"/>

                <Separator Margin="0,12" Background="#ffffff22"/>

                <!-- Log box -->
                <TextBlock Text="📋 Log:" Foreground="#aaa" FontSize="11"/>
                <ScrollViewer Height="130" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LogText}" Foreground="#86efac"
                               FontSize="10" FontFamily="Consolas"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- ===================== CỘT GIỮA: FLOW EDITOR ===================== -->
        <nodify:NodifyEditor Grid.Column="1"
                             Background="#0d1b2a"
                             x:Name="Editor"
                             ItemsSource="{Binding CurrentNodes}"
                             Connections="{Binding CurrentConnections}"
                             SelectedItem="{Binding SelectedNode, Mode=TwoWay}">

            <!-- Node location -->
            <nodify:NodifyEditor.ItemContainerStyle>
                <Style TargetType="nodify:ItemContainer">
                    <Setter Property="Location" Value="{Binding Location}"/>
                </Style>
            </nodify:NodifyEditor.ItemContainerStyle>

            <!-- Connection template -->
            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate>
                    <nodify:Connection Source="{Binding Source.OutputAnchor}"
                                       Target="{Binding Target.InputAnchor}"
                                       StrokeThickness="2" Stroke="#00AEFF"/>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

        
            <nodify:NodifyEditor.PendingConnection>
                <nodify:PendingConnection
                    Source="{Binding PendingWireSource, Mode=OneWayToSource}"
                    CompletedCommand="{Binding CreateWireCommand}"
                    StrokeThickness="2" StrokeDashArray="4 4"
                    Stroke="Yellow"
                    AllowOnlyConnectors="False"
                    EnablePreview="True"/>
            </nodify:NodifyEditor.PendingConnection>

            <!-- Context menu thêm node -->
            <nodify:NodifyEditor.ContextMenu>
                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem Header="🖱 Thêm Node: Click chuột" Command="{Binding AddClickNodeCommand}"/>
                    <MenuItem Header="⌨ Thêm Node: Gõ phím"    Command="{Binding AddTypeNodeCommand}"/>
                    <MenuItem Header="⏳ Thêm Node: Chờ"        Command="{Binding AddWaitNodeCommand}"/>
                    <MenuItem Header="🔀 Thêm Node: Rẽ nhánh"   Command="{Binding AddBranchNodeCommand}"/>
                </ContextMenu>
            </nodify:NodifyEditor.ContextMenu>

            <!-- Node template -->
            <nodify:NodifyEditor.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ActionNode}">
                    <nodify:Node Width="210" BorderThickness="1">
                        <nodify:Node.Style>
                            <Style TargetType="nodify:Node">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding NodeType}" Value="Click">
                                        <Setter Property="Background" Value="#0f3460"/>
                                        <Setter Property="BorderBrush" Value="#00AEFF"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NodeType}" Value="Type">
                                        <Setter Property="Background" Value="#134e4a"/>
                                        <Setter Property="BorderBrush" Value="#34d399"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NodeType}" Value="Wait">
                                        <Setter Property="Background" Value="#3b1f00"/>
                                        <Setter Property="BorderBrush" Value="#fbbf24"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding NodeType}" Value="Branch">
                                        <Setter Property="Background" Value="#3a0054"/>
                                        <Setter Property="BorderBrush" Value="#c084fc"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </nodify:Node.Style>

                        <!-- HEADER -->
                        <nodify:Node.Header>
                            <Grid Margin="5,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding DisplayLabel}"
                                           Foreground="White" FontWeight="Bold" TextTrimming="CharacterEllipsis"/>
                                <CheckBox Grid.Column="1" Content="Start" IsChecked="{Binding IsStartNode}"
                                          Foreground="#fbbf24" FontSize="10" Margin="4,0,0,0"/>
                            </Grid>
                        </nodify:Node.Header>

                        <!-- CONTENT -->
                        <StackPanel Margin="6">
                            <nodify:NodeInput x:Name="NodeIn"
                                             Anchor="{Binding InputAnchor, Mode=OneWayToSource}"
                                             IsHitTestVisible="False" Visibility="Collapsed"/>

                          
                            <Border Background="#00000055" CornerRadius="4" Margin="0,0,0,4"
                                    Visibility="{Binding TargetImagePath, Converter={StaticResource StrToVis}}">
                                <Image Source="{Binding TargetImagePath}" Height="50"
                                       Stretch="Uniform" Margin="2"/>
                            </Border>

                        
                            <TextBlock Text="{Binding BranchRules.Count, StringFormat='🔀 {0} cases'}"
                                       Foreground="#c084fc" FontSize="10" Margin="0,2"/>

               
                            <Button x:Name="BtnConnect"
                                    Tag="{Binding}"
                                    Click="NodeConnect_Click"
                                    Content="🔗 Ket noi"
                                    Height="28" Margin="0,6,0,0"
                                    FontSize="11" FontWeight="Bold"
                                    Background="#1e3a5f" Foreground="#00AEFF"
                                    BorderBrush="#00AEFF" BorderThickness="1"
                                    Cursor="Hand" Padding="6,2">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2a5298"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <nodify:NodeOutput Anchor="{Binding OutputAnchor, Mode=OneWayToSource}"
                                              IsHitTestVisible="False" Visibility="Collapsed"/>
                        </StackPanel>

                    </nodify:Node>
                </DataTemplate>
            </nodify:NodifyEditor.ItemTemplate>
        </nodify:NodifyEditor>

        <!-- ===================== CỘT PHẢI: NODE PROPERTIES ===================== -->
        <Border Grid.Column="2" Background="#16213e" Padding="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="⚙ Thuộc tính Node" Foreground="#00AEFF"
                               FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- Khi chưa chọn node -->
                    <TextBlock Text="← Chọn một node để chỉnh sửa"
                               Foreground="#666" FontStyle="Italic"
                               Visibility="{Binding IsNodeSelected, Converter={StaticResource BoolToVis}}"/>

                    <!-- Panel thuộc tính node (hiện khi có node được chọn) -->
                    <StackPanel DataContext="{Binding SelectedNode}"
                                Visibility="{Binding DataContext.IsNodeSelected,
                                    RelativeSource={RelativeSource AncestorType=Window},
                                    Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="Loại:" Foreground="#aaa" FontSize="11"/>
                        <TextBlock Text="{Binding NodeType}" Foreground="White"
                                   FontWeight="Bold" Margin="0,2,0,6"/>

                        <TextBlock Text="✏ Tên hiển thị:" Foreground="#aaa" FontSize="11"/>
                        <TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0d1b2a" Foreground="White"
                                 BorderBrush="#00AEFF" Padding="5,4" Margin="0,2,0,10"
                                 ToolTip="Đặt tên cho node để dễ phân biệt trong dropdown"/>

                        <!-- Click / Type node: ảnh mẫu -->
                        <StackPanel>
                            <TextBlock Text="📸 Ảnh mẫu:" Foreground="#aaa" FontSize="11"/>
                            <Border Background="#0d1b2a" CornerRadius="6" Margin="0,4,0,4" MinHeight="80">
                                <Image Source="{Binding TargetImagePath}"
                                       Stretch="Uniform" MaxHeight="120" Margin="4"/>
                            </Border>
                            <TextBlock Foreground="#fbbf24" FontSize="10" Margin="0,0,0,4">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="🎯 Điểm click: {0:P0} x {1:P0}">
                                        <Binding Path="ClickOffsetX"/>
                                        <Binding Path="ClickOffsetY"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <Button Content="🎯 Chụp ảnh mẫu" Background="#0f3460"
                                    Style="{StaticResource BtnStyle}"
                                    Command="{Binding DataContext.CaptureImageForNodeCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}"/>
                        </StackPanel>

                        <Separator Margin="0,10" Background="#ffffff22"/>

                        <!-- KET NOI NODE -->
                        <TextBlock Text="Ket noi node tiep theo:" Foreground="#00AEFF" FontWeight="Bold" FontSize="12"/>

                        <TextBlock Text="Thanh cong (OK):" Foreground="#aaa" FontSize="10" Margin="0,6,0,2"/>
                        <ComboBox x:Name="CbSuccessTarget"
                                  ItemsSource="{Binding DataContext.OtherNodes, RelativeSource={RelativeSource AncestorType=Window}}"
                                  DisplayMemberPath="DisplayLabel"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  Background="#0f3460" Foreground="White" BorderBrush="#00AEFF"
                                  Padding="6,4" Margin="0,0,0,4"/>
                        <Button Content="Noi OK" Background="#0f3460" Style="{StaticResource BtnStyle}" Margin="0,0,0,8"
                                Command="{Binding DataContext.ConnectSuccessToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding ElementName=CbSuccessTarget, Path=SelectedItem}"/>

                        <TextBlock Text="That bai (FAIL):" Foreground="#aaa" FontSize="10" Margin="0,0,0,2"/>
                        <ComboBox x:Name="CbFailTarget"
                                  ItemsSource="{Binding DataContext.OtherNodes, RelativeSource={RelativeSource AncestorType=Window}}"
                                  DisplayMemberPath="DisplayLabel"
                                  ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                  Background="#3b1f00" Foreground="White" BorderBrush="#fbbf24"
                                  Padding="6,4" Margin="0,0,0,4"/>
                        <Button Content="Noi FAIL" Background="#3b1f00" Style="{StaticResource BtnStyle}" Margin="0,0,0,4"
                                Command="{Binding DataContext.ConnectFailToCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding ElementName=CbFailTarget, Path=SelectedItem}"/>
                        <Button Content="Ngat ket noi" Background="#7f1d1d" Style="{StaticResource BtnStyle}" Margin="0,0,0,8"
                                Command="{Binding DataContext.DisconnectNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>

                        <Separator Margin="0,6" Background="#ffffff22"/>

                        <!-- Nguong khop -->
                        <TextBlock Text="Ngưỡng khớp ảnh:" Foreground="#aaa" FontSize="11"/>
                        <Slider Minimum="0.5" Maximum="1.0" TickFrequency="0.05"
                                Value="{Binding MatchThreshold}"
                                Foreground="#00AEFF" Margin="0,4,0,2"/>
                        <TextBlock Text="{Binding MatchThreshold, StringFormat={}{0:P0}}"
                                   Foreground="White" FontSize="11" HorizontalAlignment="Right"/>

                        <Separator Margin="0,10" Background="#ffffff22"/>

                        <!-- Input value (Type node) -->
                        <TextBlock Text="⌨ Nội dung gõ phím:" Foreground="#aaa" FontSize="11"/>
                        <TextBox Text="{Binding InputValue, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0d1b2a" Foreground="White"
                                 BorderBrush="#34d399" Padding="5,4" Margin="0,4,0,8"/>

                        <!-- Wait ms -->
                        <TextBlock Text="⏳ Thời gian chờ (ms):" Foreground="#aaa" FontSize="11"/>
                        <TextBox Text="{Binding WaitMs, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#0d1b2a" Foreground="White"
                                 BorderBrush="#fbbf24" Padding="5,4" Margin="0,4,0,8"/>

                        <!-- Branch rules section: chỉ hiện khi là Branch node -->
                        <StackPanel Visibility="{Binding DataContext.IsBranchNode,
                                        RelativeSource={RelativeSource AncestorType=Window},
                                        Converter={StaticResource BoolToVis}}">
                            <Separator Margin="0,10" Background="#ffffff22"/>
                            <TextBlock Text="🔀 Các case rẽ nhánh:" Foreground="#c084fc"
                                       FontWeight="Bold" FontSize="12"/>
                            <Button Content="＋ Thêm case" Background="#3a0054"
                                    Style="{StaticResource BtnStyle}" Margin="0,5,0,8"
                                    Command="{Binding DataContext.AddBranchCaseCommand,
                                        RelativeSource={RelativeSource AncestorType=Window}}"/>

                            <ItemsControl ItemsSource="{Binding DataContext.SelectedNode.BranchRules,
                                              RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0d0020" CornerRadius="6"
                                            Margin="0,0,0,8" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="Nhãn case:" Foreground="#aaa" FontSize="10"/>
                                            <TextBox Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#1a0035" Foreground="White"
                                                     BorderBrush="#c084fc" Padding="4,3" Margin="0,2,0,5"/>

                                            <Border Background="#1a0035" CornerRadius="4" MinHeight="50" Margin="0,0,0,5">
                                                <Image Source="{Binding TargetImagePath}"
                                                       Stretch="Uniform" MaxHeight="70" Margin="3"/>
                                            </Border>

                                            <Button Content="📸 Chụp ảnh case" Background="#4c1d95"
                                                    Style="{StaticResource BtnStyle}"
                                                    Command="{Binding DataContext.CaptureImageForBranchCaseCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>

                                            <TextBlock Text="→ Node tiếp theo:" Foreground="#aaa" FontSize="10" Margin="0,5,0,2"/>
                                            <ComboBox ItemsSource="{Binding DataContext.AllNodes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      DisplayMemberPath="DisplayLabel"
                                                      SelectedValue="{Binding NextNodeId, UpdateSourceTrigger=PropertyChanged}"
                                                      SelectedValuePath="NodeId"
                                                      ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
                                                      Background="#1a0035" Foreground="#c084fc"
                                                      BorderBrush="#c084fc" Padding="4,3" FontSize="10"/>

                                            <TextBlock Text="Priority (nhỏ = ưu tiên hơn):" Foreground="#aaa" FontSize="10" Margin="0,5,0,2"/>
                                            <TextBox Text="{Binding Priority, UpdateSourceTrigger=PropertyChanged}"
                                                     Background="#1a0035" Foreground="White"
                                                     BorderBrush="#c084fc" Padding="4,3" FontSize="10"/>

                                            <Button Content="🗑 Xóa case" Background="#7f1d1d"
                                                    Style="{StaticResource BtnStyle}" Margin="0,6,0,0"
                                                    Command="{Binding DataContext.DeleteBranchCaseCommand,
                                                        RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </StackPanel><!-- /Branch section -->

                        <Separator Margin="0,10" Background="#ffffff22"/>

                        <Button Content="🗑 Xóa node này" Background="#7f1d1d"
                                Style="{StaticResource BtnStyle}"
                                Command="{Binding DataContext.DeleteNodeCommand,
                                    RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>