<Window x:Class="AutoRpaTool.RegionSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        WindowState="Maximized" Topmost="True"
        Cursor="Cross"
        MouseLeftButtonDown="OnMouseDown"
        MouseMove="OnMouseMove"
        MouseLeftButtonUp="OnMouseUp"
        KeyDown="OnKeyDown">

    <Canvas x:Name="MainCanvas">
        <!-- Overlay tối toàn màn hình -->
        <Rectangle x:Name="Overlay" Fill="#88000000"
                   Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=Window}}"
                   Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=Window}}"/>

        <!-- Vùng sáng chọn -->
        <Rectangle x:Name="SelectionRect"
                   Stroke="#00AEFF" StrokeThickness="2"
                   Fill="#33FFFFFF"
                   Visibility="Collapsed"/>

        <TextBlock Canvas.Left="10" Canvas.Top="10"
                   Text="Kéo để chọn vùng chụp ảnh. Nhấn ESC để hủy."
                   Foreground="White" FontSize="16" FontWeight="Bold">
            <TextBlock.Effect>
                <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2"/>
            </TextBlock.Effect>
        </TextBlock>
    </Canvas>
</Window>
